# Copy to .env and fill in values. Never commit .env.

# --- Telegram bot (required for run_bot.py) ---
TG_TOKEN=

# --- Anthropic API (required for generation) ---
ANTHROPIC_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=16384
GENERATION_MAX_RETRIES=1
MAX_SPEC_CHARS=120000

# --- Maven validation in Docker (production-ready gate) ---
MAVEN_VALIDATION_ENABLED=true
MAVEN_VALIDATION_STRICT=true
MAVEN_DOCKER_IMAGE=maven:3.9-eclipse-temurin-17
MAVEN_TIMEOUT_SEC=300
MAVEN_MAX_RETRIES=1

# --- Scaffold (recommended: leave true) ---
USE_SCAFFOLD=true

# --- Tester quota (optional; only this Telegram user id is limited) ---
# Get id from @userinfobot or bot logs. Leave empty to disable quotas.
TESTER_TELEGRAM_ID=
TESTER_MAX_RUNS=5
USAGE_STORE_PATH=data/usage.json

# --- Local CLI (run_local.py) ---
# TG_TOKEN is not required when using run_local.py only.
# Example:
#   python run_local.py --spec fixtures/httpbin-live-testing-api.json --base-url https://httpbin.org
